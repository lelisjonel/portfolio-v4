# Strapi Environment Variables
# Copy this file to .env and fill in your values

# Strapi API URL (change to your production URL when deploying)
VITE_STRAPI_URL=http://localhost:1337

# Strapi API Token (create in Strapi Admin > Settings > API Tokens)
# For public read access, you may not need a token
# For form submissions, create a token with create permissions on contact-inquiries
VITE_STRAPI_TOKEN=
